# =============================================================================
# forgeplan — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# NEVER commit .env to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# Required — OpenProject Connection
# -----------------------------------------------------------------------------

# OpenProject instance URL (any reachable host: VPS, cloud, local Docker, SaaS)
OP_BASE_URL="https://op.example.com"

# OpenProject API token (Bearer auth)
OP_API_KEY="opapi-xxxxxxxxxxxxxxxxxxxx"

# OpenProject project slug identifier
OP_PROJECT_ID="my-project"

# Absolute path to the mono-repo root
REPO_ROOT="/home/dev/repo"

# -----------------------------------------------------------------------------
# Optional — Git Configuration
# -----------------------------------------------------------------------------

# Git remote name for push (default: origin)
# GIT_REMOTE="origin"

# Base branch for new feature branches (default: develop)
# GIT_BASE_BRANCH="develop"

# -----------------------------------------------------------------------------
# Optional — Git Hosting (for PR creation)
# -----------------------------------------------------------------------------

# Platform for PR creation: github | gitlab | bitbucket
# GIT_HOST_TYPE="github"

# Personal access token for Git hosting API (required if GIT_HOST_TYPE is set)
# GIT_HOST_TOKEN="ghp_xxxxxxxxxxxxxxxxxxxx"

# Repository slug for PR API (required if GIT_HOST_TYPE is set)
# GIT_HOST_REPO="org/repo-name"

# Comma-separated PR reviewer usernames
# REVIEWERS="alice,bob"

# -----------------------------------------------------------------------------
# Optional — Claude Code
# -----------------------------------------------------------------------------

# Claude model identifier (default: claude-sonnet-4-20250514)
# CLAUDE_MODEL="claude-sonnet-4-20250514"

# Max seconds for Claude Code invocation (default: 600)
# GENERATION_TIMEOUT="600"

# Max retry attempts after transient API failure (default: 3)
# CLAUDE_MAX_RETRIES="3"

# Initial retry delay in seconds, doubles each retry (default: 10)
# CLAUDE_RETRY_DELAY="10"

# -----------------------------------------------------------------------------
# Optional — Validation
# -----------------------------------------------------------------------------

# Post-generation validation command (e.g., build + lint)
# VALIDATION_CMD="npm run lint && npm run build"

# Max seconds for validation command (default: 120)
# VALIDATION_TIMEOUT="120"

# -----------------------------------------------------------------------------
# Optional — Prompt Budget
# -----------------------------------------------------------------------------

# Approximate max tokens for the assembled prompt (default: 30000)
# PROMPT_MAX_TOKENS="30000"

# -----------------------------------------------------------------------------
# Optional — Logging
# -----------------------------------------------------------------------------

# Directory for structured logs (default: ./logs)
# LOG_DIR="./logs"

# Print actions without executing (default: false)
# DRY_RUN="false"

{
  "name": "@forgeplan/mcp-server",
  "version": "1.0.0-alpha",
  "description": "MCP server for forgeplan — bridges OpenProject work packages to AI-driven code generation",
  "type": "module",
  "license": "MIT",
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },

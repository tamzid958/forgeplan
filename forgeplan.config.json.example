{
  "openproject": {
    "url": "https://op.example.com",
    "projectId": "my-project"
  },
  "layers": {
    "backend": {
      "path": "src/backend",
      "techStack": "ASP.NET 8, C#, Entity Framework Core",
      "filePatterns": ["**/*.cs", "**/*.csproj"],
      "buildCmd": "dotnet build"
    },
    "frontend": {
      "path": "src/frontend",
      "techStack": "Next.js 14, TypeScript, Tailwind CSS",
      "filePatterns": ["**/*.tsx", "**/*.ts"],
      "buildCmd": "npm run build",
      "openproject": {
        "projectId": "frontend-project"
      }
    }
  },
  "routingField": "category",
  "routingMap": {
    "Backend": "backend",
    "Frontend": "frontend",
    "Full-Stack": ["backend", "frontend"]
  },
  "defaultLayer": "backend",
  "reviewers": ["alice", "bob"],
  "hooks": {},
  "statuses": {
    "_comment": "Run 'forgeplan --remap-statuses' to populate this section",
    "pickup_status": null,
    "in_progress_status": null,
    "success_status": null,
    "partial_status": null,
    "failure_status": null,
    "_status_ids": {}
  }
}
